<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.projectgestaltt.MainController"
      style="-fx-background-color: #c8b89a;">

    <!-- Barra de título -->
    <HBox style="-fx-background-color: #2a2318; -fx-padding: 10 16;"
          spacing="12" alignment="CENTER_LEFT">
        <Label text="[ PROJECT GESTALT ] — COMPILADOR NieR"
               style="-fx-text-fill: #c8b89a; -fx-font-size: 14px;
                      -fx-font-weight: bold;
                      -fx-font-family: 'Courier New', monospace;"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="[ ABRIR ]"   onAction="#onAbrir"   styleClass="btn-accion"/>
        <Button text="[ GUARDAR ]" onAction="#onGuardar" styleClass="btn-accion"/>
    </HBox>

    <!-- Editor y árbol -->
    <SplitPane VBox.vgrow="ALWAYS" dividerPositions="0.5"
               style="-fx-background-color: #c8b89a; -fx-padding: 6;">

        <VBox style="-fx-background-color: #c8b89a; -fx-border-color: #8a7a60; -fx-border-width: 1;">
            <Label text="// EDITOR DE CÓDIGO" styleClass="panel-titulo"/>
            <TextArea fx:id="editorCodigo" VBox.vgrow="ALWAYS"/>
        </VBox>

        <VBox style="-fx-background-color: #c8b89a; -fx-border-color: #8a7a60; -fx-border-width: 1;">
            <Label text="// ÁRBOL DE DERIVACIÓN" styleClass="panel-titulo"/>
            <TextArea fx:id="areaArbol" VBox.vgrow="ALWAYS" editable="false"/>
        </VBox>

    </SplitPane>

    <!-- Barra de botones -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: #2a2318; -fx-padding: 8 14;">
        <Button text="[ COMPILAR ]" onAction="#onCompilar"
                style="-fx-background-color: #c8b89a; -fx-text-fill: #2a2318;
                       -fx-font-weight: bold; -fx-padding: 6 16;
                       -fx-background-radius: 0;
                       -fx-font-family: 'Courier New', monospace;"/>
        <Button text="[ LIMPIAR ]" onAction="#onLimpiar"
                style="-fx-background-color: #7a2a1a; -fx-text-fill: #c8b89a;
                       -fx-font-weight: bold; -fx-padding: 6 16;
                       -fx-background-radius: 0;
                       -fx-font-family: 'Courier New', monospace;"/>
        <Button text="[ EJEMPLO ]" onAction="#onEjemplo"
                style="-fx-background-color: #3d3020; -fx-text-fill: #c8b89a;
                       -fx-font-weight: bold; -fx-padding: 6 16;
                       -fx-background-radius: 0;
                       -fx-font-family: 'Courier New', monospace;"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Label text="STATUS: " style="-fx-text-fill: #c8b89a;
               -fx-font-family: 'Courier New', monospace; -fx-font-size: 11px;"/>
        <Label fx:id="lblEstado" text="LISTO" styleClass="estado-neutro"/>
    </HBox>

    <!-- Tablas en pestañas -->
    <TabPane prefHeight="240"
             style="-fx-background-color: #c8b89a;">

        <Tab text="TOKENS" closable="false">
            <TableView fx:id="tablaTokens">
                <columns>
                    <TableColumn fx:id="colTipoToken"    text="TIPO"    prefWidth="180"/>
                    <TableColumn fx:id="colValorToken"   text="VALOR"   prefWidth="180"/>
                    <TableColumn fx:id="colLineaToken"   text="LÍNEA"   prefWidth="70"/>
                    <TableColumn fx:id="colColumnaToken" text="COL"     prefWidth="70"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </Tab>

        <Tab text="ERRORES" closable="false">
            <TableView fx:id="tablaErrores">
                <columns>
                    <TableColumn fx:id="colTipoError"    text="TIPO"        prefWidth="100"/>
                    <TableColumn fx:id="colLineaError"   text="LÍNEA"       prefWidth="70"/>
                    <TableColumn fx:id="colColumnaError" text="COL"         prefWidth="70"/>
                    <TableColumn fx:id="colDescError"    text="DESCRIPCIÓN" prefWidth="400"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </Tab>

        <Tab text="SÍMBOLOS" closable="false">
            <TableView fx:id="tablaSimbolos">
                <columns>
                    <TableColumn fx:id="colNombreSim" text="NOMBRE"  prefWidth="150"/>
                    <TableColumn fx:id="colTipoSim"   text="TIPO"    prefWidth="100"/>
                    <TableColumn fx:id="colAmbitoSim" text="ÁMBITO"  prefWidth="120"/>
                    <TableColumn fx:id="colLineaSim"  text="LÍNEA"   prefWidth="70"/>
                    <TableColumn fx:id="colValorSim"  text="VALOR"   prefWidth="150"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </Tab>

    </TabPane>

</VBox>